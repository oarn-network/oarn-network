# OARN Network - Environment Variables
# Copy this to .env and fill in your values

# Node 1 private key (required)
OARN_PRIVATE_KEY=0x...

# Additional nodes for multi-node setup (optional)
OARN_PRIVATE_KEY_2=0x...
OARN_PRIVATE_KEY_3=0x...

# RPC URL (defaults to Arbitrum Sepolia)
OARN_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# For mainnet, use:
# OARN_RPC_URL=https://arb1.arbitrum.io/rpc
